# LLM provider: openai | ollama | google | auto
LLM_PROVIDER=openai

# OpenAI settings
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# Ollama settings
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gpt-oss:20b

# Google Gemini settings
GOOGLE_GEMINI_API_KEY=
GOOGLE_MODEL=gemini-2.5-pro

# Optional runtime defaults
TARGET_DIR=
DRY_RUN=true
IGNORE_LIST_PATH=
UPDATE_IGNORE_LIST=true

# Naming language: pl | en | be | ru
NAMING_LANG=en

# Optional extraction settings
# setup.sh will set this automatically; or set manually to <PROJECT_ROOT>/.venv/bin/python
READER_PYTHON=python3
OCR_LANG=pol+eng+rus
