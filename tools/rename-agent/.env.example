# LLM provider: openai | ollama | google | auto
LLM_PROVIDER=openai

# OpenAI settings
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# Ollama settings
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gpt-oss:20b

# Google Gemini settings
GOOGLE_GEMINI_API_KEY=
GOOGLE_MODEL=gemini-2.5-pro

# Optional runtime defaults
TARGET_DIR=/Users/serj/projects/poland/src
DRY_RUN=true
IGNORE_LIST_PATH=/Users/serj/projects/poland/src/.rename-agent-ignore.txt
UPDATE_IGNORE_LIST=true

# Optional extraction settings
READER_PYTHON=python3
# READER_SCRIPT_PATH=/Users/serj/projects/poland/tools/read_document.py
OCR_LANG=pol+eng+rus
