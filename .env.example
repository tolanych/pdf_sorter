# ═══════════════════════════════════════════════════════════════════════
# LLM PROVIDER & MODEL
# ═══════════════════════════════════════════════════════════════════════
# Choose one provider. If not set — auto-detected by API keys present below.
# Fallback: ollama (works offline, no keys needed).
#
# Allowed values: ollama | openai | google | openrouter
LLM_PROVIDER=ollama

# Model within the chosen provider.
# If not set — provider's default is used (see table below).
#
# Provider defaults:
#   ollama      → gpt-oss:20b
#   openai      → gpt-4o-mini
#   google      → gemini-2.5-pro
#   openrouter  → openrouter/auto
LLM_MODEL=gpt-oss:20b

# ═══════════════════════════════════════════════════════════════════════
# PROVIDER API KEYS & SETTINGS
# ═══════════════════════════════════════════════════════════════════════
# Fill in ONLY the section for your chosen provider.

# --- Ollama (local, free, no key needed) ---
OLLAMA_BASE_URL=http://localhost:11434

# --- OpenAI ---
OPENAI_API_KEY=
OPENAI_TIMEOUT_MS=90000
OPENAI_MAX_RETRIES=2

# --- Google Gemini ---
GOOGLE_GEMINI_API_KEY=

# --- OpenRouter (OpenAI-compatible gateway, free & paid models) ---
OPENROUTER_API_KEY=

# ═══════════════════════════════════════════════════════════════════════
# RUNTIME DEFAULTS
# ═══════════════════════════════════════════════════════════════════════
TARGET_DIR=
DRY_RUN=true

# Naming language: en | pl | be | ru
NAMING_LANG=en

# Ignore lists
RENAME_IGNORE_LIST_PATH=
IGNORE_LIST_PATH=
ORGANIZE_IGNORE_LIST_PATH=
UPDATE_IGNORE_LIST=true
ORGANIZE_UPDATE_IGNORE_LIST=true

# ═══════════════════════════════════════════════════════════════════════
# OCR & DOCUMENT READING
# ═══════════════════════════════════════════════════════════════════════
# Path to venv Python (setup.sh sets this automatically)
READER_PYTHON=.venv/bin/python
# EasyOCR language codes (comma-separated)
OCR_LANG=en,ru,be,uk

# ═══════════════════════════════════════════════════════════════════════
# VISION MODEL (for organize:smart image classification)
# ═══════════════════════════════════════════════════════════════════════
# Optional. If not set — vision uses the same LLM_PROVIDER + LLM_MODEL.
# To use a DIFFERENT provider/model for vision, set both:
#   VISION_PROVIDER=<provider>
#   VISION_MODEL=<model>
#
# Examples:
#   VISION_PROVIDER=ollama    VISION_MODEL=gemma3:4b
#   VISION_PROVIDER=openai    VISION_MODEL=gpt-4o
#   VISION_PROVIDER=openrouter VISION_MODEL=google/gemma-3-4b-it:free
VISION_PROVIDER=ollama
VISION_MODEL=gemma3:4b
