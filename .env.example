# Model to use by default (must be supported by tools/rename-agent/src/llm.mjs)
# Priority in code:
# 1) LLM_MODEL
# 2) OPENAI_MODEL (only if OPENAI_API_KEY is set)
# 3) OLLAMA_MODEL
# 4) GOOGLE_MODEL (only if GOOGLE_GEMINI_API_KEY is set)
# Fallback: gpt-oss:20b
LLM_MODEL=gpt-oss:20b

# OpenAI settings
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_TIMEOUT_MS=90000
OPENAI_MAX_RETRIES=2

# Ollama settings
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gpt-oss:20b

# Google Gemini settings
GOOGLE_GEMINI_API_KEY=
GOOGLE_MODEL=gemini-2.5-pro

# Optional runtime defaults
TARGET_DIR=
DRY_RUN=true
# Rename flow ignore list (apply)
RENAME_IGNORE_LIST_PATH=
# Backward-compatible alias for rename ignore list:
IGNORE_LIST_PATH=
# Organize flow ignore list (organize / organize:smart)
ORGANIZE_IGNORE_LIST_PATH=
UPDATE_IGNORE_LIST=true
ORGANIZE_UPDATE_IGNORE_LIST=true

# Naming language: pl | en | be | ru
NAMING_LANG=en

# Optional extraction settings
# IMPORTANT: READER_PYTHON must point to the venv python, not system python3
# setup.sh sets this automatically to <PROJECT_ROOT>/.venv/bin/python
READER_PYTHON=.venv/bin/python
# EasyOCR language codes (comma-separated)
OCR_LANG=en,ru,be,uk

# Optional vision model for organize:smart image classification
# VISION_MODEL=gpt-4o
# Example for local Ollama vision:
VISION_MODEL=gemma3:4b
